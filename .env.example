# Forecast API (FastAPI)
# Local default in development is http://127.0.0.1:8000.
# In production, set this to your reachable forecast API host (or leave empty for same-origin).
REACT_APP_FORECAST_API_BASE=

# Environmental API (Node/Express)
# Local default in development is http://localhost:5000.
# In production, set this to your reachable environmental API host (or leave empty for same-origin).
REACT_APP_ENV_API_BASE=
